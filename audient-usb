#!/bin/sh

# ==============================================================================
# Script Name: audient-usb
# Description: Fixes Audient iD audio interfaces disconnect/drop issues 
#              after Linux system suspend/sleep.
# Author:      moonessence
# Co-Author:   Gemini Flash AI Assistant
# License:     MIT License
# Repository:  https://github.com/moonessence/audient-usb-sleep-fix
# ==============================================================================

# Target Audient Vendor ID (Works for iD4, iD14, and other hardware revisions)
VENDOR_ID="2708"

clog() {
    logger -t audient-usb "[audient-usb] $1"
    echo "[audient-usb] $1"
}

get_audient_port() {
    vendor_id="$1"
    
    for dev_path in /sys/bus/usb/devices/*; do
        if [ -d "$dev_path" ]; then
            # POSIX-compliant and fast way to skip USB interfaces (containing ':')
            case "$dev_path" in
                *:*) continue ;;
            esac
            
            if [ -f "$dev_path/idVendor" ]; then
                current_vendor_id=$(cat "$dev_path/idVendor" 2>/dev/null)
                
                if [ "$current_vendor_id" = "$vendor_id" ]; then
                    # Pure POSIX alternative to the 'basename' command
                    echo "${dev_path##*/}"
                    return 0
                fi
            fi
        fi
    done
    return 1
}

case "$1" in
    pre)
        PORT=$(get_audient_port "$VENDOR_ID")
        
        if [ -n "$PORT" ]; then
            clog "Preparing Audient on port $PORT for suspend..."
            
            if [ -f "/sys/bus/usb/devices/$PORT/power/control" ]; then
                echo "auto" > "/sys/bus/usb/devices/$PORT/power/control" 2>/dev/null
            fi
            sync
            
            if [ -f "/sys/bus/usb/drivers/usb/unbind" ]; then
                echo "$PORT" > "/sys/bus/usb/drivers/usb/unbind" 2>/dev/null
                clog "Audient successfully isolated before suspend."
            fi
        else
            clog "Audient device not found, suspending normally."
        fi
        ;;
        
    post)
        clog "System resumed. Waiting for USB bus initialization..."
        
        PORT=""
        i=1
        
        # POSIX-compliant loop (without 'seq') - 10 seconds total timeout (20 * 0.5s)
        while [ "$i" -le 20 ]; do
            PORT=$(get_audient_port "$VENDOR_ID")
            
            if [ -n "$PORT" ]; then
                break
            fi
            
            sleep 0.5
            i=$((i + 1))
        done

        if [ -n "$PORT" ]; then
            if [ -f "/sys/bus/usb/drivers/usb/bind" ]; then
                echo "$PORT" > "/sys/bus/usb/drivers/usb/bind" 2>/dev/null
            fi
            
            if [ -f "/sys/bus/usb/devices/$PORT/power/control" ]; then
                echo "on" > "/sys/bus/usb/devices/$PORT/power/control" 2>/dev/null
            fi
            clog "Audient on port $PORT successfully resumed and stabilized."
        else
            clog "CRITICAL ERROR: Audient failed to reappear on the USB bus after resume!"
        fi
        ;;
esac
